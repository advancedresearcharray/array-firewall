{
  "version": 1,
  "network": {
    "role": "gateway",
    "cutover": false,
    "hostname": "array-firewall",
    "lan_if": "eth0",
    "wan_if": "eth1",
    "uplink_if": "eth1",
    "lan_cidr": "192.0.2.0/24",
    "mgmt_cidr": "192.0.2.0/24",
    "gateway_ip": "192.0.2.3",
    "default_posture": "deny_new_devices",
    "unsolicited_wan": "deny",
    "nat": true
  },
  "api_allow_cidrs": [],
  "zones": {
    "enabled": true,
    "google_router_ip": "192.0.2.2",
    "wireless": {
      "groups": ["google-mesh", "wireless-infra"],
      "ip_ranges": ["192.0.2.3-192.0.2.50"]
    },
    "trusted": {
      "groups": ["infrastructure", "gaming", "laptops"],
      "ip_ranges": ["192.0.2.51-192.0.2.250"]
    },
    "bridge": {
      "groups": ["bridge", "laptops"],
      "macs": []
    },
    "allow": {
      "gateway_dns": true,
      "wireless_internet": true,
      "trusted_internet": true,
      "restricted_internet": true,
      "restricted_lateral": false
    },
    "restricted": {
      "groups": ["guest", "iot"],
      "ip_ranges": ["192.0.2.201-192.0.2.250"]
    }
  },
  "defaults": {
    "internet": "deny_until_approved",
    "dns_filter": "off",
    "qos_profile": "balanced",
    "log_denied": true
  },
  "dhcp": {
    "enabled": true,
    "interface": "eth0",
    "range_start": "198.51.100.50",
    "range_end": "198.51.100.200",
    "netmask": "255.255.255.0",
    "lease_time": "12h",
    "gateway": "192.0.2.3",
    "dns": "192.0.2.3",
    "domain": "array-firewall.local",
    "upstream_dns": ["1.1.1.1", "8.8.8.8"],
    "authoritative": true,
    "reservations": []
  },
  "qos_profiles": {
    "low": { "description": "Proxmox / LXC / VM / mesh — deprioritized" },
    "balanced": { "description": "Default house traffic — medium priority" },
    "gaming": { "description": "Xbox / Warzone — dedicated bandwidth" }
  },
  "qos": {
    "enabled": true,
    "wan_if": "eth1",
    "lan_if": "eth0",
    "wan_up": "950mbit",
    "wan_down": "950mbit",
    "contract_up": "1000mbit",
    "contract_down": "1000mbit",
    "sync": true,
    "xbox_ip": "203.0.113.11",
    "xbox_rate": "874mbit",
    "marks": {
      "xbox": 16,
      "wireless": 20,
      "laptop": 32,
      "phone": 40,
      "other": 48,
      "high": 16,
      "medium": 32,
      "low": 48
    },
    "classes": {
      "xbox": { "rate": "400mbit", "ceil": "931mbit", "prio": 1 },
      "wireless": { "rate": "200mbit", "ceil": "836mbit", "prio": 2 },
      "laptop": { "rate": "150mbit", "ceil": "700mbit", "prio": 3 },
      "phone": { "rate": "100mbit", "ceil": "500mbit", "prio": 4 },
      "other": { "rate": "50mbit", "ceil": "200mbit", "prio": 5 },
      "high": { "rate": "400mbit", "ceil": "931mbit", "prio": 1 },
      "medium": { "rate": "150mbit", "ceil": "700mbit", "prio": 3 },
      "low": { "rate": "50mbit", "ceil": "200mbit", "prio": 5 }
    },
    "mode": "auto",
    "autorate_recommended": false
  },
  "devices": {},
  "device_groups": {
    "infrastructure": {
      "name": "Infrastructure",
      "description": "Servers, LXCs, and VMs",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "low",
        "dns_filter": "off",
        "packet_shield": "off"
      }
    },
    "iot": {
      "name": "IoT",
      "description": "Smart home and sensors",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "balanced",
        "dns_filter": "on",
        "packet_shield": "off"
      }
    },
    "guest": {
      "name": "Guest",
      "description": "Guest WiFi clients — internet only, no lateral LAN",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "balanced",
        "dns_filter": "on",
        "packet_shield": "off",
        "dhcp_allocate": true
      }
    },
    "gaming": {
      "name": "Gaming",
      "description": "Xbox and gaming clients",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "high",
        "dns_filter": "off",
        "packet_shield": "normal",
        "dhcp_allocate": true
      }
    },
    "google-mesh": {
      "name": "Google Mesh",
      "description": "Nest/Google Wifi — DHCP from Google router at .2 (wireless zone)",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "high",
        "dns_filter": "off",
        "packet_shield": "off",
        "dhcp_allocate": false
      }
    },
    "bridge": {
      "name": "Zone bridge",
      "description": "Devices allowed to cross wireless ↔ trusted barrier (e.g. admin laptop)",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "balanced",
        "dns_filter": "off",
        "packet_shield": "off",
        "dhcp_allocate": true
      }
    },
    "wireless-infra": {
      "name": "Wireless infrastructure",
      "description": "Access points, mesh nodes, routers",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "high",
        "dns_filter": "off",
        "packet_shield": "off",
        "dhcp_allocate": false
      }
    },
    "laptops": {
      "name": "Laptops",
      "description": "Admin and household laptops (priority 3)",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "balanced",
        "dns_filter": "off",
        "packet_shield": "off"
      }
    },
    "phones": {
      "name": "Phones",
      "description": "Mobile devices (priority 4)",
      "members": [],
      "config": {
        "internet": "allowed",
        "qos_profile": "balanced",
        "dns_filter": "off",
        "packet_shield": "off"
      }
    }
  },
  "ids": {
    "enabled": true,
    "mode": "log_only",
    "scan_interval_sec": 30,
    "ai_enabled": true,
    "ollama_url": "http://192.0.2.60:11434",
    "ollama_model": "llama3.2:1b",
    "connection_spike_threshold": 80,
    "port_scan_threshold": 12,
    "block_ttl_sec": 3600,
    "quarantine_on_high": true,
    "auto_reload": true
  },
  "port_forwards": [],
  "dmz": {
    "enabled": false,
    "host_ip": "203.0.113.11",
    "host_mac": "aa:bb:cc:dd:ee:ff",
    "name": "xbox"
  },
  "upnp": {
    "enabled": true,
    "secure_mode": true,
    "xbox_only": true,
    "lease_seconds": 3600,
    "allow_lan": true
  },
  "dns_filter": {
    "enabled": true,
    "force_lan_dns": true,
    "block_doh_dot": true,
    "feeds": [
      "https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"
    ],
    "custom_domains": []
  },
  "blocklists": {
    "dns": [],
    "nft": []
  },
  "gaming": {
    "xbox_ip": "203.0.113.11",
    "xbox_mac": "aa:bb:cc:dd:ee:ff",
    "packet_shield_in_match_only": true,
    "sentinel_port": 8098,
    "mitigation": {
      "tiny_packet_only": true,
      "auto_block_peers": false,
      "auto_ids_block": false,
      "auto_shield_sync": true,
      "matchmaking_allowlist": true,
      "console_mode": true,
      "auto_block_vps_peers": false,
      "lobby_reputation_gate": false,
      "auto_route_pref_in_match": false,
      "peer_ttl_sec": 86400,
      "ids_block_ttl_sec": 3600,
      "per_source_udp_rate": 500,
      "conn_cap_per_peer": 40,
      "min_mitigate_interval_sec": 15,
      "repeat_offender_hits": 3,
      "repeat_offender_ttl_sec": 604800,
      "honeypot_enabled": true,
      "sink_port": 39217,
      "auto_block_on_probe": true,
      "auto_block_wan_scanners": true,
      "wan_scan_block": {
        "enabled": true,
        "ttl_sec": 86400,
        "block_on_first_probe": true
      },
      "subnet_block": {
        "enabled": true,
        "default_ttl_days": 30,
        "prefix_len": 24,
        "auto_block_on_vps_mesh": true,
        "auto_block_vps_mesh_subnet": true,
        "enforce_provider_ranges": false,
        "provider_ttl_days": 365,
        "provider_refresh_hours": 168,
        "max_active_subnets": 512,
        "providers": {
          "vultr": "https://cloud-ip-ranges.com/download/vultr.txt",
          "linode": "https://cloud-ip-ranges.com/download/linode.txt",
          "digitalocean": "https://cloud-ip-ranges.com/download/digitalocean.txt",
          "hetzner": "https://cloud-ip-ranges.com/download/hetzner.txt"
        }
      },
      "probe_block_ttl_sec": 86400,
      "tcp_rst_non_game": true,
      "auto_route_pref_in_match": true,
      "peer_rate_limits_enabled": true
    },
    "afld": {
      "enabled": true,
      "retention_sec": 86400,
      "rollup_min_bytes": 8192,
      "kinds": ["wan_scan", "probe_sink", "honeypot"]
    },
    "allowlist_learn": {
      "enabled": true,
      "prefix_len": 24,
      "min_hits": 3,
      "max_new_cidrs": 8,
      "auto_apply_in_match": false
    },
    "rqd": {
      "enabled": true,
      "prune_threshold": 0.15,
      "max_depth": 6,
      "shortcut_cache": true,
      "auto_buffer_in_match": false
    },
    "asvi": {
      "enabled": true,
      "prefix_len": 24,
      "stage_threshold": 0.35,
      "act_threshold": 0.65,
      "min_hits": 2,
      "auto_stage_allowlist": false
    },
    "throughput_fold": {
      "enabled": true,
      "wire_min_bytes": 512,
      "auto_wire_sentinel": true,
      "blsb_before_gzip": true,
      "include_fold_sidecar": true,
      "pattern_rle_before_blsb": true
    },
    "pattern_encode": {
      "enabled": true,
      "min_bytes": 64,
      "min_gain_pct": 3.0,
      "max_pattern_len": 32,
      "include_analysis": true
    },
    "qce": {
      "enabled": true,
      "min_rows": 3,
      "investigate_boost": 18.0,
      "peak_entropy_band": true,
      "include_iit_phi": true
    },
    "upload_assist": {
      "enabled": true,
      "ceil_factor": 0.98,
      "other_ceil_factor": 0.55,
      "xbox_rate_factor": 0.85,
      "pressure_warn_pct": 80,
      "in_match_desync_buffer": true,
      "auto_boost_in_lobby": true,
      "buffer": {
        "gaming_xbox_rtt": "8ms",
        "gaming_ifb_rtt": "8ms",
        "desync_xbox_rtt": "5ms",
        "desync_ifb_rtt": "5ms",
        "kick_xbox_rtt": "3ms",
        "kick_ifb_rtt": "3ms",
        "xbox_memlimit": "4mb",
        "ifb_memlimit": "8mb"
      }
    },
    "download_assist": {
      "enabled": true,
      "ceil_factor": 0.98,
      "ifb_rtt": "3ms",
      "ifb_memlimit": "32mb",
      "auto_boost_in_lobby": true
    }
  },
  "perf": {
    "enabled": true,
    "gpu_enabled": true,
    "gpu_url": "http://192.0.2.50:8795",
    "dscp_gaming": true,
    "buffer_profiles": true,
    "kernel_tune": true,
    "autorate_on_boot": false,
    "autorate_before_apply": false,
    "autorate_factor": 0.95
  },
  "ai_ops": {
    "enabled": true,
    "mode": "assist",
    "tick_interval_sec": 5,
    "ollama_planner": true,
    "auto_ids_scan": true,
    "auto_buffer_on_spike": true,
    "auto_ids_on_hostile": true,
    "min_confidence_shield": 0.45,
    "min_confidence_block": 0.72,
    "min_confidence_subnet": 0.80,
    "override_tiny_packet_only": false,
    "max_blocks_per_tick": 8,
    "max_subnets_per_tick": 2,
    "learning_rate": 0.08,
    "fleet_sync_enabled": true,
    "fleet_sync_interval_sec": 300,
    "pre_burst_enabled": true,
    "pre_burst_window_sec": 90,
    "negative_allowlist_enabled": true,
    "negative_allowlist_ttl_sec": 604800,
    "adaptive_shield_enabled": true,
    "rqd_investigate_on_peak": true,
    "gpu_fusion_enabled": true,
    "replay_lab_enabled": true,
    "game_state_fusion_enabled": true,
    "fuse_weights": {
      "sentinel_likely": 0.35,
      "vps_probe": 0.40,
      "identical_burst": 0.25,
      "asvi_act": 0.30,
      "qce_peak": 0.25,
      "ids_ai_high": 0.30,
      "repeat_offender": 0.20,
      "game_kick": 0.35,
      "game_cheat_event": 0.12,
      "game_player_flag": 0.08
    }
  },
  "custom_hooks": []
}
